// minimum number of dropped packets
"rewmin": R{"dropped_packets"}min=?[F sched=0 & t=T-1 & k=K-1 ];
// maximum number of packets sent (dual property)
"rewmaxpackets": R{"packets_sent"}max=?[F sched=0 & t=T-1 & k=K-1 ];
// maximum reward (based on priorities)
"rewmax": R{"priority"}max=?[F sched=0 & t=T-1 & k=K-1 ];
